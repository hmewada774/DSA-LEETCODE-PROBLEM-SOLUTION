class Solution {
public:
    bool searchMatrix(vector<vector<int>>& matrix, int target) { //tc = O(log(m*n))
        int m = matrix.size();
        int n = matrix[0].size();
        int i = 0, j = n-1;
        matrix[i][j];
        while(i<m && j >=0){
            if(matrix[i][j] == target){
                return true;
            }
            else if(matrix[i][j] > target ){
                j--;
            }else{
                i++;
            }
        }
        return false;
    }
};
