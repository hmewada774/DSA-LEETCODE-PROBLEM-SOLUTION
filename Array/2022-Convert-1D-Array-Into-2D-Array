class Solution {
public:
    vector<vector<int>> construct2DArray(vector<int>& original, int m, int n) {
       if(original.size() != m*n){
        return {};
       }
       vector<vector<int>> res(m, vector<int>(n));
       int i = 0, j = 0;
       for(int num: original ){
        res[i][j++] = num;
        if(j>=n){
            j = 0; 
            i++;
        }

       }
       return res;
    }
};
