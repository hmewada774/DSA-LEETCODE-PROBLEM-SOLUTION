class Solution {
public:
    bool isPalindrome(string s) {
        int st = 0, end = s.size() - 1;

        while(st < end){
            if(!isalnum(s[st])) {
                st++;
            }
            else if(!isalnum(s[end])) {
                end--;
            }
            else {
                if(tolower(s[st]) != tolower(s[end])) {
                    return false;
                }
                st++;
                end--;
            }
        }
        return true;
    }
};
